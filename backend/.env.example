PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/stockflow
JWT_SECRET=change-this-to-a-long-random-secret-key-in-production
JWT_EXPIRES_IN=7d
UPLOADS_DIR=./uploads

